{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Delta VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/delta-context-engine"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/delta-context-engine/dist/**/*.js"
      ]
    }
  ]
}
