# Delta ignore patterns

# Dependencies
node_modules/**
**/node_modules/**

# Build outputs
dist/**
build/**
.next/**
out/**

# Generated files
*.generated.ts
*.generated.js

# Test coverage
coverage/**

# Delta internal
.delta/**

# VS Code extension package (entire packages/ directory)
packages/**
packages/delta-context-engine/**
packages/delta-context-engine/src/**

# Config files
.claude/**
