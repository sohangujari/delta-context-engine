  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/delta-context-engine.git"
  },
  "license": "MIT",
  "author": "Your Name",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
