{
  "name": "delta-ctx",
  "version": "0.1.0",
  "description": "Delta Context Engine — Only send what changed.",
  "keywords": [
    "claude",
    "ai",
    "context",
    "tokens",
    "mcp",
    "developer-tools",
    "claude-code"
  ],
  "homepage": "https://github.com/yourusername/delta-context-engine",
